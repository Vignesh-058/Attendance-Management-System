# Database Config
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=attendance_db

# JWT Config
# CRITICAL: These must be set to secure, random strings in production
JWT_SECRET=supersecretjwtkey123_change_me_in_prod
JWT_REFRESH_SECRET=superrefreshsecret456_change_me_in_prod
JWT_EXPIRES_IN=15m

# Admin Initial Config (Used during database seeding)
ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=ComplexAdminPassword1!

# Email Config (SMTP for password reset)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user
SMTP_PASS=your_ethereal_password

# Redis Config
REDIS_HOST=redis
REDIS_PORT=6379

# Server Port
PORT=3000
